table R-t2-NodeFailureRCABreakdown
	lineageTag: 8aff7681-d42d-4f05-a2f2-57cdca2822ac

	measure 'Top 3 Category Reasons (Max Week)' =
			
			VAR MaxWeek = [MaxWeekR]
			VAR TopNReasonsTable =
			    TOPN(
			        3,
			        FILTER(
			            ALLSELECTED('R-t2-NodeFailureRCABreakdown'),
			            'R-t2-NodeFailureRCABreakdown'[Week] = MaxWeek
			        ),
			        'R-t2-NodeFailureRCABreakdown'[FailureCount], DESC
			    )
			VAR SortedTopNReasonsTable =
			    ADDCOLUMNS(
			        TopNReasonsTable,
			        "ConcatenationString",
			        "    " & 'R-t2-NodeFailureRCABreakdown'[Category] & ": " & 'R-t2-NodeFailureRCABreakdown'[Reason] & " (" & 'R-t2-NodeFailureRCABreakdown'[FailureCount] & ")"
			    )
			VAR ConcatCategoryReason =
			    CONCATENATEX(
			        -- Now sort this table directly
			        SortedTopNReasonsTable,
			        [ConcatenationString],
			        UNICHAR(10),
			        -- Explicitly specify the order for CONCATENATEX
			        'R-t2-NodeFailureRCABreakdown'[FailureCount], DESC
			    )
			RETURN
			    ConcatCategoryReason
		lineageTag: 46b65cf6-9431-4486-aeaa-aa4a9272de09

