	partition J-r1-na = m
		mode: import
		queryGroup: Reliability
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "test", "let FailureCategories = datatable(failureCategory: string)#(lf)[#(lf)    ""User Stop"",#(lf)    ""Hardware Failure"",#(lf)    ""Software Failure""#(lf)];#(lf)let ReactTime_table = cluster('luciatrainingplatform.westcentralus.kusto.windows.net').database('test').JobReactTime;#(lf)let Summary_table = cluster('luciatrainingplatform.westcentralus.kusto.windows.net').database('test').JobSummary;#(lf)Summary_table#(lf)| join kind=inner ReactTime_table on jobId#(lf)| extend Week = weekofyear(startofweek(launchTime - 1d, 0)) // Monday as the start of the week#(lf)| summarize#(lf)    AvgUserStop = avgif(reactTime, failureCategory == ""User Stop""),#(lf)    AvgHardwareFailure = avgif(reactTime, failureCategory == ""Hardware Failure""),#(lf)    AvgSoftwareFailure = avgif(reactTime, failureCategory == ""Software Failure""),#(lf)    AvgReactionTime = avg(reactTime), // Calculate the average reactTime directly#(lf)    MaxUserStop = maxif(reactTime, failureCategory == ""User Stop""),#(lf)    MaxHardwareFailure = maxif(reactTime, failureCategory == ""Hardware Failure""),#(lf)    MaxSoftwareFailure = maxif(reactTime, failureCategory == ""Software Failure""),#(lf)    MaxReactionTime = max(reactTime)#(lf)by Week#(lf)| order by Week asc| where Week != ''", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

