table NR-t0-ORFNodeRecycleTime
	lineageTag: 05cf2cb7-9830-428d-996c-79d26aee49b0

	measure 'OFR Recycle Last' = ```
			
			VAR LastWeek = [MaxWeek2]
			VAR FilteredTableForLatWeek =
			    FILTER(
			        'NR-t0-ORFNodeRecycleTime',
			        'NR-t0-ORFNodeRecycleTime'[Week] = LastWeek
			    )
			VAR Result = 
			    AVERAGEX(
			        FilteredTableForLatWeek,
			        'NR-t0-ORFNodeRecycleTime'[Node Recycle Time (Hour)]
			    )
			RETURN COALESCE(Result, 0)
			```
		lineageTag: 194241de-5e38-4a0d-ae20-e9d665046a17

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'OFR Recycle Previous' = ```
			
			VAR PreviousWeek = [MaxWeek2]-1
			VAR FilteredTableForLatWeek =
			    FILTER(
			        'NR-t0-ORFNodeRecycleTime',
			        'NR-t0-ORFNodeRecycleTime'[Week] = PreviousWeek
			    )
			VAR Result = 
			    AVERAGEX(
			        FilteredTableForLatWeek,
			        'NR-t0-ORFNodeRecycleTime'[Node Recycle Time (Hour)]
			    )
			RETURN COALESCE(Result, 0)
			```
		lineageTag: 0663ecab-c916-4ab1-98fd-115d57463e57

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'OFR Recycle Change' =
			
			IF(
			    [OFR Recycle Previous] > [OFR Recycle Last],
			    "decreased",
			    IF(
			        [OFR Recycle Previous] < [OFR Recycle Last],
			        "increased",
			        "unchanged"
			    )
			)
		lineageTag: e9355fd0-df26-45d6-9b3f-c0f45c972ff3

