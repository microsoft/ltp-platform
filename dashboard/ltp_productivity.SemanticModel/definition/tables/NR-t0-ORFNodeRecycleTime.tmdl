	partition NR-t0-ORFNodeRecycleTime = m
		mode: import
		queryGroup: Availability
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "production", "//UA_Time: Issue Detected to UA#(lf)//Allocation_Time: Wait for Allocation#(lf)//Validation_Time: Node Return Processing#(lf)//UA_cycle_Time: UA cycle#(lf)//Node Recyle time: sum of UA_cycle_Time for same big_group_id#(lf)//UA times in Single Recycle:  Node Recyle time/UA_cycle_Time#(lf)let start_actions = dynamic([""cordoned"", ""new""]);#(lf)let ua = ""ua"";#(lf)let ua_dealloc = ""deallocated_ua"";#(lf)let ua_alloc = ""allocated_ua"";#(lf)let end_actions = dynamic([""available"", ""deallocated_capacity""]);#(lf)let data_with_flags = cluster('luciatrainingplatform.westcentralus.kusto.windows.net').database('production').NodeStatusRecord#(lf)| distinct Timestamp, HostName, Status, Endpoint#(lf)| join kind=leftouter #(lf)    (VMInfo #(lf)    | distinct HostName, VMSS)#(lf)on HostName#(lf)    | extend VMSS_clean = trim("" "", tolower(VMSS))#(lf)    | join kind=leftouter(#(lf)        ClusterVMSSInfo#(lf)        | extend VMSS_clean = trim("" "", tolower(VMSSName))#(lf)    ) on VMSS_clean#(lf)| extend Timestamp = todatetime(['Timestamp'])#(lf)| where isnotempty(HostName) and isnotempty(Status)#(lf)| sort by HostName  asc, Timestamp  asc, Status asc#(lf)| serialize#(lf)| extend#(lf)    is_start = iif(Status in (start_actions), 1, 0),#(lf)    is_end = iif(Status in (end_actions), 1, 0),#(lf)    is_ua = iif(Status == ua, 1, 0),#(lf)    is_ua_dealloc = iif(Status == ua_dealloc, 1, 0),#(lf)    is_ua_alloc = iif(Status == ua_alloc, 1, 0)#(lf)| extend is_big_start = iff(Status in (start_actions) and prev(Status) in (end_actions), 1 ,0)#(lf)| extend big_group_id = row_cumsum(is_big_start)#(lf)| extend group_key = strcat(HostName, ""_"", tostring(big_group_id))#(lf)| serialize#(lf)| extend sub_group_id = row_cumsum(is_start, group_key != prev(group_key))#(lf)| project-away HostName1;#(lf)let duplicated_rows =#(lf)    data_with_flags#(lf)    | where is_start == 1 and sub_group_id >1#(lf)    | extend sub_group_id = sub_group_id - 1;#(lf)let final_data =#(lf)    data_with_flags#(lf)    | union duplicated_rows#(lf)    | sort by HostName, Timestamp, sub_group_id;#(lf)let summary_final_data =#(lf)final_data#(lf)| summarize#(lf)    StartTime = minif(Timestamp, is_start == 1),#(lf)    UAedTime = minif(Timestamp, is_ua == 1),#(lf)    UADeallocTime = minif(Timestamp, is_ua_dealloc == 1),#(lf)    UAAllocTime = minif(Timestamp, is_ua_alloc == 1),#(lf)    EndTime = max(Timestamp)#(lf)  by HostName, big_group_id, sub_group_id, Endpoint, ClusterName#(lf)| where isnotnull(StartTime) and isnotnull(UADeallocTime)#(lf)| extend#(lf)    UA_Time = todouble(UADeallocTime - StartTime)/todouble(1h),#(lf)    Allocation_Time = todouble(UAAllocTime - UADeallocTime)/todouble(1h),#(lf)    Validation_Time = todouble(EndTime - UAAllocTime)/todouble(1h),#(lf)    UA_cycle_Time = todouble(EndTime - StartTime)/todouble(1h)#(lf)| sort by StartTime#(lf)| extend NodeRecycleEventID = strcat(HostName, '_', big_group_id)#(lf)| project-away UADeallocTime, UAAllocTime;#(lf)let node_recycle_event =#(lf)summary_final_data#(lf)| summarize#(lf)    EventStartTime = min(StartTime),#(lf)    EventEndTime = max(EndTime),#(lf)    EventUACycleTime = sum(UA_cycle_Time),#(lf)    CountUAAction = countif(isnotnull(UA_cycle_Time))#(lf)by NodeRecycleEventID#(lf)| extend Week = weekofyear(startofweek(EventStartTime - 1d, 0));// Monday as the start of the week#(lf)let new_summary_final_data_env =#(lf)summary_final_data#(lf)| join kind=leftouter (#(lf)    node_recycle_event#(lf)) on NodeRecycleEventID;#(lf)let aggregated_weekly_env_1 =#(lf)new_summary_final_data_env#(lf)| summarize#(lf)    UACycleTime_weekly = avg(UA_cycle_Time),#(lf)    UATime_weekly = avg(UA_Time),#(lf)    AllocationTime_weekly = avg(Allocation_Time),#(lf)    ValidationTime_weekly = avg(Validation_Time)#(lf)by Week, ClusterName, Endpoint;#(lf)let aggregated_weekly_env_2 =#(lf)new_summary_final_data_env#(lf)| summarize take_any(EventUACycleTime), take_any(CountUAAction) by NodeRecycleEventID, Week, ClusterName, Endpoint#(lf)| summarize#(lf)    NodeCount = dcount(NodeRecycleEventID), // correct#(lf)    NodeRecycleTime_weekly = avg(EventUACycleTime),#(lf)    UATimeinSingleRecycel_weekly = avg(CountUAAction)#(lf)by Week, ClusterName, Endpoint;#(lf)aggregated_weekly_env_1#(lf)| join kind=inner aggregated_weekly_env_2 on Week, ClusterName, Endpoint#(lf)| project-away Week1, Endpoint1, ClusterName1#(lf)| order by Week asc", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null]),
				    #"Renamed Columns" = Table.RenameColumns(Source,{{"NodeCount", "Node Count"}, {"NodeRecycleTime_weekly", "Node Recycle Time (Hour)"}, {"UATimeinSingleRecycel_weekly", "UA Count in Single Recycle"}, {"UACycleTime_weekly", "UA Cycle"}, {"UATime_weekly", "Issue Deteted to UA"}, {"AllocationTime_weekly", "Wait for Allocation"}, {"ValidationTime_weekly", "Node Return Processing"}})
				in
				    #"Renamed Columns"

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

