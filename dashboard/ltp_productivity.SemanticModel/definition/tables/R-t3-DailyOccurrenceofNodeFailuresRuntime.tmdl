table R-t3-DailyOccurrenceofNodeFailuresRuntime
	lineageTag: 8595c03f-a2a4-4eff-932b-360c9c8cd83e

	measure MaxTotalForMaxWeek =
			
			VAR LatestWeek = [MaxWeekR]
			VAR Result =
			    CALCULATE(
			        MAXX(
			            FILTER(
			                ALLSELECTED('R-t3-DailyOccurrenceofNodeFailuresRuntime'),
			                'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Week] = LatestWeek
			            ),
			            'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Total]
			        )
			    )
			RETURN
			    COALESCE(Result, 0)
		formatString: 0
		lineageTag: 4e4e5958-a8af-4e4a-a912-2b18b9a3dab8

	measure DateWithMaxTotalForMaxWeek =
			
			VAR DDate = CALCULATE(
			    MAXX(
			        FILTER(
			            ALLSELECTED('R-t3-DailyOccurrenceofNodeFailuresRuntime'),
			            'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Week] = [MaxWeekR] &&
			            'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Total] = [MaxTotalForMaxWeek] // Filter to only rows with the max total
			        ),
			        'R-t3-DailyOccurrenceofNodeFailuresRuntime'[StartDate] // Return the StartDate
			    )
			)
			RETURN
			IF(
			    [MaxTotalForMaxWeek] = 0,
			    "",
			    DDate
			)
		formatString: mmmm d
		lineageTag: 99c7ee97-2b9f-4f26-b7bf-a2ea15e9fd4d

		annotation PBI_FormatHint = {"isDateTimeCustom":true}

	measure EndpointWithMaxTotalForMaxWeek = ```
			
			VAR Endpoint = 
			CALCULATE(
			    MAXX( // Using MAXX here, but you might consider MINX or SELECTEDVALUE if you expect only one Endpoint per MaxTotal
			        FILTER(
			            ALLSELECTED('R-t3-DailyOccurrenceofNodeFailuresRuntime'),
			            'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Week] = [MaxWeekR] &&
			            'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Total] = [MaxTotalForMaxWeek]
			        ),
			        'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Endpoint]
			    )
			)
			RETURN
			IF(
			    [MaxTotalForMaxWeek] = 0,
			    "",
			    Endpoint
			)
			```
		lineageTag: cff8b37b-0f06-4d40-98fd-1bbbfd575087

	measure CategoryWithMaxTotalForMaxWeek =
			
			VAR Cat =
			CALCULATE(
			    MAXX( // Using MAXX here, but you might consider MINX or SELECTEDVALUE if you expect only one Endpoint per MaxTotal
			        FILTER(
			            ALLSELECTED('R-t3-DailyOccurrenceofNodeFailuresRuntime'),
			            'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Week] = [MaxWeekR] &&
			            'R-t3-DailyOccurrenceofNodeFailuresRuntime'[Total] = [MaxTotalForMaxWeek]
			        ),
			        'R-t3-DailyOccurrenceofNodeFailuresRuntime'[CategoryNew]
			    )
			)
			RETURN
			IF(
			    [MaxTotalForMaxWeek] = 0,
			    "",
			    Cat
			)
		lineageTag: dabb7346-0827-49dc-beeb-686e69dc2773

