		sourceColumn: R-r1-na[Category]

		annotation SummarizationSetBy = Automatic

	partition R-t4-DailyNodeRuntimeAvgFailure = calculated
		mode: import
		source = ```
				
				ADDCOLUMNS(
				    SUMMARIZE(
				        'R-r1-na',
				        'R-r1-na'[Week],
				        'R-r1-na'[Date],
				        'R-r1-na'[Endpoint],
				        'R-r1-na'[Category]
				    ),
				    "Avg. Failure", 
				    DIVIDE(
				        SUMX(
				            FILTER(
				                'R-r1-na',
				                'R-r1-na'[Week] = EARLIER('R-r1-na'[Week] ) &&
				                'R-r1-na'[Endpoint] = EARLIER('R-r1-na'[Endpoint]) &&
				                'R-r1-na'[Category] = EARLIER('R-r1-na'[Category])
				            ),
				            'R-r1-na'[WeeklyTotal]
				        ),
				        AVERAGEX(
				            FILTER(
				                'R-r1-na',
				                'R-r1-na'[Week] = EARLIER('R-r1-na'[Week]) &&
				                'R-r1-na'[Endpoint] = EARLIER('R-r1-na'[Endpoint]) &&
				                'R-r1-na'[Category] = EARLIER('R-r1-na'[Category])
				            ),
				            'R-r1-na'[DaysinWeek]
				        ),
				        0
				    )
				)
				```

	annotation PBI_Id = 8920d8a619a046319ecdb3cd4955055c

