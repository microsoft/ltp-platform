	partition R-r0-na = m
		mode: import
		queryGroup: Reliability
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "production", "//1.for the runtime failures, the source data will change into NodeActionRecord in production cluster:#(lf)//here is an example runtime failure query#(lf)let record =#(lf)cluster('https://luciatrainingplatform.westcentralus.kusto.windows.net/').database('production').table('NodeActionRecord')#(lf)| join kind=leftouter (#(lf)    NodeActionAttributes#(lf)) on Action#(lf)| sort by HostName asc , Timestamp asc, Action asc#(lf)| extend PrevHostName = prev(HostName, 1)#(lf)| extend PrevPhase = prev(Phase, 1)#(lf)| extend IsNewNode = HostName != PrevHostName or isnull(PrevHostName)#(lf)| serialize#(lf)| extend LastPhase = iff(#(lf)    IsNewNode,#(lf)    Phase,  // First record for this node#(lf)    iff(#(lf)        isnotempty(Phase),#(lf)        Phase,  // Current action has phase#(lf)        iff(#(lf)            isnotempty(PrevPhase),#(lf)            PrevPhase,  // Use previous phase#(lf)            """"  // Default to empty#(lf)        )#(lf)    )#(lf))#(lf)| project-away PrevHostName, PrevPhase, IsNewNode, Action1#(lf)| sort by Timestamp asc#(lf)| where Action contains ""cordoned-triaged"" and LastPhase contains ""routine""#(lf)| extend CategoryReason = strcat(Category, ""-"", Reason);#(lf)let startDate = datetime(2025-03-17);#(lf)let endDate = now();#(lf)// Step 1: Extract unique reasons in the 'routine' phase#(lf)let uniqueReasonsRoutine = record#(lf)| distinct CategoryReason;#(lf)// Step 2: Summarize count by reason within weekly intervals#(lf)let summarizedData = record#(lf)| summarize Count = count() by CategoryReason, bin(Timestamp, 7d);#(lf)// Step 3: Pivot the data to create a column for each unique reason#(lf)summarizedData#(lf)| evaluate pivot(CategoryReason, sum(Count))#(lf)| extend Week = weekofyear(startofweek(Timestamp - 1d, 0)) // Monday as the start of the week#(lf)| extend Date = format_datetime(Timestamp, ""yyyy-MM-dd"")#(lf)| order by Week asc#(lf)", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Exception

	annotation PBI_NavigationStepName = Navigation

