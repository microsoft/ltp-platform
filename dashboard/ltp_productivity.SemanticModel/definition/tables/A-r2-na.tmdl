	partition A-r2-na = m
		mode: import
		queryGroup: Availability
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "production", "//2.for the availability status, it will change into NodeStatusRecord in production cluster:#(lf)//here is an example per day status count query#(lf)let NSR =#(lf)    cluster('https://luciatrainingplatform.westcentralus.kusto.windows.net/').database('production').table('NodeActionRecord');#(lf)let min_day = toscalar(NodeStatusRecord | summarize startofday(min(Timestamp)));#(lf)let max_day = toscalar(NodeStatusRecord | summarize startofday(max(Timestamp)));#(lf)let AllDays = range Day from min_day to max_day step 1d;#(lf)// Step 1: Get all Groups from StatusAttributes#(lf)let AllGroups = NodeStatusAttributes | summarize by Group;#(lf)// Step 2: Build all (Day, Group) combinations#(lf)let AllCombos =#(lf)    AllGroups#(lf)    | extend dummy = 1#(lf)    | join kind=inner (#(lf)        AllDays | extend dummy = 1#(lf)    ) on dummy#(lf)    | project Day, Group;#(lf)// Step 3: Get latest status per node per day#(lf)let LatestPerNodePerDay =#(lf)    NodeStatusRecord#(lf)    | join kind=leftouter(#(lf)        VMInfo#(lf)    ) on HostName#(lf)    | extend VMSS_clean = trim("" "", tolower(VMSS))#(lf)    | join kind=leftouter(#(lf)        ClusterVMSSInfo#(lf)        | extend VMSS_clean = trim("" "", tolower(VMSSName))#(lf)    ) on VMSS_clean#(lf)    | extend DayList = range(min_day, max_day, 1d)#(lf)    | mv-expand Day = DayList to typeof(datetime)#(lf)    | where startofday(Timestamp) <= Day#(lf)    | summarize arg_max(Timestamp, Status) by HostName, Day, Endpoint, ClusterName;#(lf)// Step 4: Map statuses to groups#(lf)let NodeStatusWithGroup =#(lf)    LatestPerNodePerDay#(lf)    | extend Status_clean = trim("" "", tolower(Status))#(lf)    | join kind=leftouter (#(lf)        NodeStatusAttributes#(lf)        | extend Status_clean = trim_start(@""[^\w]+"",Status)#(lf)    ) on Status_clean;#(lf)// Step 5: Count nodes per group per day#(lf)let DailyGroupCounts =#(lf)    NodeStatusWithGroup#(lf)    | summarize NodeCount = count() by Day, Group, Endpoint, ClusterName;#(lf)// Step 6: Merge with full (Day, Group) grid to include 0s#(lf)let DailyGroupNodeCounts =#(lf)    AllCombos#(lf)    | join kind=leftouter (DailyGroupCounts) on Day, Group#(lf)    | extend NodeCount = coalesce(NodeCount, 0)#(lf)    | sort by Day asc, Group asc#(lf)    | project-away Day1, Group1;#(lf)// Step 7:#(lf)DailyGroupNodeCounts#(lf)| summarize arg_max(NodeCount, *) by Day, Group, Endpoint // Ensure all columns are available for pivoting#(lf)| evaluate pivot(Group, sum(NodeCount))#(lf)| where isnotempty(Endpoint) // Add this line to filter out empty Endpoints#(lf)| order by Day asc, Endpoint asc#(lf)| extend Week = weekofyear(startofweek(Day - 1d, 0)) // Monday as the start of the week", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

