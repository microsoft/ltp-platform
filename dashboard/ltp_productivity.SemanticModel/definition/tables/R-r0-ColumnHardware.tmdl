table R-r0-ColumnHardware
	lineageTag: a12f1e3d-aefe-40e0-beae-c78ba6376702

	column 'Reasons in Category: Hardware'
		dataType: string
		lineageTag: 87765ec8-9a27-4f8b-b9fa-9811e8cd4833
		summarizeBy: none
		sourceColumn: Reasons in Category: Hardware

		annotation SummarizationSetBy = Automatic

	partition R-r0-ColumnHardware = m
		mode: import
		queryGroup: Reliability
		source =
				let
				    Source = #table(type table [ColumnName = text], {}),
				    TableSchema = Table.Schema( #"R-r0-na" ),
				    ColumnNames = Table.SelectColumns(TableSchema, {"Name"}),
				    FilteredHardwareColumns = Table.SelectRows(ColumnNames, each Text.StartsWith([Name], "hardware")),
				    ListofHardwareColumns = FilteredHardwareColumns[Name], // This is currently a list of text values
				
				    // Step 1: Remove 'Hardware-' prefix from each item in the list
				    RenamedColumnsStep1 = List.Transform(ListofHardwareColumns, each Text.Replace(_, "hardware-", "")), // Corrected: using '_' instead of '$'
				
				    // Step 2: Replace "" (empty string) with "UnknownReason"
				    RenamedColumnsStep2 = List.Transform(RenamedColumnsStep1, each if Text.Length(_) = 0 then "Unknown Reason" else _), // Corrected: using '_'
				
				    // Convert the list back to a table (optional, but good for Power BI loading)
				    FinalTable = Table.FromList(RenamedColumnsStep2, Splitter.SplitByNothing(), {"Reasons in Category: Hardware"}, null, ExtraValues.Error)
				in
				    FinalTable

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

