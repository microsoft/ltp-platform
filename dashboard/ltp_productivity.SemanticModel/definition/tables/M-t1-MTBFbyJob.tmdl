	partition M-t1-MTBFbyJob = m
		mode: import
		queryGroup: Reliability
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "test", "let JobActions = cluster('https://luciatrainingplatform.westcentralus.kusto.windows.net/').database('test').table('JobSummary')#(lf)| where failureCategory in (""Hardware Failure"")#(lf)| project-away userName, jobState, retryCount, attemptId, retryDetails, totalGpuCount, jobPriority, totalGpuHours, idleGpuHours, effectiveGpuHours, failureReason, jobHash#(lf)| extend Week = weekofyear(startofweek(launchTime - 1d, 0)) // Monday as the start of the week#(lf)| sort by launchTime asc;#(lf)let Res = JobActions#(lf)| order by Week asc#(lf)| summarize #(lf)    MTBIHours = avg(jobDurationHours),#(lf)    SampleCount = count()#(lf)by Week#(lf)| order by Week asc;#(lf)let CumulativeRes = Res#(lf)| extend CumulativeTotalHours = row_cumsum(SampleCount * MTBIHours)#(lf)| extend CumulativeSampleCount = row_cumsum(SampleCount)#(lf)| extend CumulativeMTBIHours = iff(CumulativeSampleCount > 0, todouble(CumulativeTotalHours) / CumulativeSampleCount, 0.0);#(lf)CumulativeRes", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

