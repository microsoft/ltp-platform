	partition M-t1-MTBFbyJob = m
		mode: import
		queryGroup: Availability
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "test", "let JobActions = cluster('https://luciatrainingplatform.westcentralus.kusto.windows.net/').database('test').table('JobSummary')#(lf)| where failureCategory in (""Hardware Failure"")#(lf)| project-away userName, jobState, retryCount, attemptId, retryDetails, totalGpuCount, jobPriority, totalGpuHours, idleGpuHours, effectiveGpuHours, failureReason, jobHash#(lf)| extend Week = weekofyear(startofweek(launchTime - 1d, 0)) // Monday as the start of the week#(lf)| sort by launchTime asc;#(lf)let Res = JobActions#(lf)| order by Week asc#(lf)| summarize #(lf)    WeeklyAverageDurationHours = avg(jobDurationHours)#(lf)by Week#(lf)| order by Week asc;#(lf)Res#(lf)", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

