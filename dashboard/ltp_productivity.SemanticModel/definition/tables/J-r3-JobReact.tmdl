	partition J-r3-JobReact = m
		mode: import
		queryGroup: Job
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "production", "let ReactTime_table = cluster('luciatrainingplatform.westcentralus.kusto.windows.net').database('production').JobReactTime;#(lf)let Summary_table = cluster('luciatrainingplatform.westcentralus.kusto.windows.net').database('production').JobSummary;#(lf)let ReactTime =#(lf)Summary_table#(lf)| summarize arg_max(timeGenerated, *) by jobId#(lf)| join kind=inner ReactTime_table on jobId#(lf)| extend Week = weekofyear(startofweek(launchTime - 1d, 0)); // Monday as the start of the week#(lf)ReactTime", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

