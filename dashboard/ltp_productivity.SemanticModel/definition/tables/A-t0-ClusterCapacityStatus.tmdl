	partition A-t0-ClusterCapacityStatus = calculated
		mode: import
		source =
				
				SELECTCOLUMNS(
				    ADDCOLUMNS(
				        'A-r0-na',
				        "TotalVMs_Intermediate",
				        'A-r0-na'[AvgReadyEmpty] + 'A-r0-na'[AvgReadyUsed] + 'A-r0-na'[AvgOFR] +
				        'A-r0-na'[AvgUnallocatable] + 'A-r0-na'[AvgHumanInvestigate] +
				        'A-r0-na'[AvgExcluded] + 'A-r0-na'[AvgProbation] + 'A-r0-na'[AvgSuspected]
				    ),
				    "Date", 'A-r0-na'[Week],
				    "Cluster", 'A-r0-na'[Cluster],
				    "Allocated", DIVIDE(
				        'A-r0-na'[AvgReadyUsed],
				        [TotalVMs_Intermediate]
				    ),
				    "Available VMs (Empty)", DIVIDE(
				        'A-r0-na'[AvgReadyEmpty],
				        [TotalVMs_Intermediate]
				    ),
				    "OFR", DIVIDE(
				        'A-r0-na'[AvgOFR],
				        [TotalVMs_Intermediate]
				    ),
				    "Unallocatable", DIVIDE(
				        'A-r0-na'[AvgUnallocatable],
				        [TotalVMs_Intermediate]
				    ),
				    "Others", DIVIDE(
				        'A-r0-na'[AvgHumanInvestigate] + 'A-r0-na'[AvgExcluded] + 'A-r0-na'[AvgProbation] + 'A-r0-na'[AvgSuspected],
				        [TotalVMs_Intermediate]
				    ),
				    "Total VM Count (Weekly Avg.)", [TotalVMs_Intermediate],
				    "Week", [WeekNum]
				)

	annotation PBI_Id = 4836dd236f984777b82391a3185e19ae

