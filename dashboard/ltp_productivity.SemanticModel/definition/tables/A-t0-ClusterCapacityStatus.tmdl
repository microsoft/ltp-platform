table A-t0-ClusterCapacityStatus
	lineageTag: 468ac673-14a6-4ddc-bd52-85ebdf9d78e0

	measure 'Available GPU Ratio' =
			
			CALCULATE(
			    AVERAGE('A-t0-ClusterCapacityStatus'[Available VMs (Empty)]),
			    FILTER(
			        'A-t0-ClusterCapacityStatus',
			        'A-t0-ClusterCapacityStatus'[Week] = MAX('A-t0-ClusterCapacityStatus'[Week])
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 42f5ee17-a043-4d11-8dad-a8e0aa33bb56

		extendedProperty MeasureTemplate =
				{
				  "version": 0,
				  "daxTemplateName": "AveragePerCategory"
				}

	measure 'Available GPU Count' =
			
			CALCULATE(
			    SUMX(
			        FILTER(
			            'A-t0-ClusterCapacityStatus',
			            'A-t0-ClusterCapacityStatus'[Week] = MAX('A-t0-ClusterCapacityStatus'[Week])
			        ),
			        'A-t0-ClusterCapacityStatus'[Available VMs (Empty)] * 'A-t0-ClusterCapacityStatus'[Total VM Count (Weekly Avg.)] * 8
			    )
			)
		lineageTag: 80b12db9-6ac5-476e-9e7a-fe6f8c6a2a03

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'OFR GPU Count' =
			
			CALCULATE(
			    SUMX(
			        FILTER(
			            'A-t0-ClusterCapacityStatus',
			            'A-t0-ClusterCapacityStatus'[Week] = MAX('A-t0-ClusterCapacityStatus'[Week])
			        ),
			        'A-t0-ClusterCapacityStatus'[OFR] * 'A-t0-ClusterCapacityStatus'[Total VM Count (Weekly Avg.)] * 8
			    )
			)
		lineageTag: a34dbe0c-256f-47cc-94a9-a5827fcf2280

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'OFR GPU Ratio' =
			
			CALCULATE(
			    AVERAGE('A-t0-ClusterCapacityStatus'[OFR]),
			    FILTER(
			        'A-t0-ClusterCapacityStatus',
			        'A-t0-ClusterCapacityStatus'[Week] = MAX('A-t0-ClusterCapacityStatus'[Week])
			    )
			)
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 48e55498-5310-4c39-8d7f-60d8d6db8dca

	measure 'Availability Alert' = ```
			
			    SWITCH(
			        TRUE(),
			
			        [Available GPU Ratio] < 0.05 && [OFR GPU Ratio] >= 0.05,
			        "Low Available ratio and high OFR ratio may cause potential insufficiency. Please investigate.",
			    
			        [Available GPU Ratio] >= 0.05 && [OFR GPU Ratio] >= 0.05,
			        "High OFR ratio may cause potential insufficiency. Please investigate.",
			    
			        [Available GPU Ratio] < 0.05 && [OFR GPU Ratio] < 0.05,
			        "Low Available ratio may cause potential insufficiency. Please investigate.",
			    
			        BLANK() -- Returns nothing if the condition is not met
			    )
			```
		lineageTag: c206a646-6a70-4acc-88cf-e08151c9cfec

