	partition J-r0-na = m
		mode: import
		queryGroup: Reliability
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "test", "let FailureCategories = datatable(failureCategory: string)#(lf)[#(lf)    ""User Stop"",#(lf)    ""Hardware Failure"",#(lf)    ""Software Failure""#(lf)];#(lf)let JobSummaryData = cluster('luciatrainingplatform.westcentralus.kusto.windows.net').database('test').JobSummary;#(lf)JobSummaryData#(lf)| extend Week = weekofyear(startofweek(launchTime - 1d, 0)) // Monday as the start of the week#(lf)| summarize#(lf)    AvgJobDuration = avg(jobDurationHours),#(lf)    counts_UserStop = countif(failureCategory == ""User Stop""),#(lf)    counts_HardwareFailure = countif(failureCategory == ""Hardware Failure""),#(lf)    counts_SoftwareFailure = countif(failureCategory == ""Software Failure""),#(lf)    counts_total = count(),#(lf)    MaxUserStop = maxif(jobDurationHours, failureCategory == ""User Stop""),#(lf)    MaxHardwareFailure = maxif(jobDurationHours, failureCategory == ""Hardware Failure""),#(lf)    MaxSoftwareFailure = maxif(jobDurationHours, failureCategory == ""Software Failure""),#(lf)    MaxDuration = max(jobDurationHours)#(lf)by failureCategory, Week#(lf)| join kind=rightouter FailureCategories on failureCategory#(lf)| summarize#(lf)    AvgUserStop = avgif(AvgJobDuration, failureCategory == ""User Stop""),#(lf)    AvgHardwareFailure = avgif(AvgJobDuration, failureCategory == ""Hardware Failure""),#(lf)    AvgSoftwareFailure = avgif(AvgJobDuration, failureCategory == ""Software Failure""),#(lf)    counts_UserStop = sum(counts_UserStop),#(lf)    counts_HardwareFailure = sum(counts_HardwareFailure),#(lf)    counts_SoftwareFailure = sum(counts_SoftwareFailure),#(lf)    counts_total = sum(counts_total),#(lf)    MaxUserStop = max(MaxUserStop),#(lf)    MaxHardwareFailure = max(MaxHardwareFailure),#(lf)    MaxSoftwareFailure = max(MaxSoftwareFailure),#(lf)    MaxDuration = max(MaxDuration)#(lf)by Week#(lf)| join kind=inner (#(lf)    JobSummaryData#(lf)    | extend Week = weekofyear(startofweek(launchTime - 1d, 0)) // Ensure the same Week calculation#(lf)    | summarize AvgDuration = avg(jobDurationHours) by Week#(lf)) on Week#(lf)| order by Week asc#(lf)| project-away Week1| where Week != ''", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

