	partition M-r0-HWJobActions = m
		mode: import
		queryGroup: Job
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "production", "let JobActions = cluster('https://luciatrainingplatform.westcentralus.kusto.windows.net/').database('production').table('JobSummary')#(lf)| summarize arg_max(timeGenerated, *) by jobId#(lf)| where exitCategory in (""Hardware Failure"")#(lf)| project-away userName, jobState, retryCount, attemptId, retryDetails, jobPriority, totalGpuHours, idleGpuHours, effectiveGpuHours, exitReason, jobHash#(lf)| extend Week = weekofyear(startofweek(launchTime - 1d, 0)) // Monday as the start of the week#(lf)| sort by launchTime asc;#(lf)JobActions", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

