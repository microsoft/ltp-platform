table M-r0-HWJobActions
	lineageTag: 4ca0a83b-3a72-47d7-999f-bb747a7fcac5

	measure CumulativeSampleCount =
			
			COUNTROWS(
			    FILTER(
			        ALLSELECTED('M-r0-HWJobActions'),
			        'M-r0-HWJobActions'[Week] <= MAX('M-r0-HWJobActions'[Week]) && 'M-r0-HWJobActions'[Endpoint] = MAX('M-r0-HWJobActions'[Endpoint])
			    )
			)
		formatString: 0
		lineageTag: a40e3dbe-5122-4105-9e71-c51eca93206d

	measure CumulativeMTBIHours =
			
			VAR CurrentEndpoint = MAX('M-r0-HWJobActions'[Endpoint])
			VAR CurrentWeek = MAX('M-r0-HWJobActions'[Week])
			RETURN
			    CALCULATE(
			        DIVIDE(
			            SUMX(
			                FILTER(
			                    ALL('M-r0-HWJobActions'), // Use ALL to clear existing filters for cumulative calculation
			                    'M-r0-HWJobActions'[Endpoint] = CurrentEndpoint && 'M-r0-HWJobActions'[Week] <= CurrentWeek
			                ),
			                'M-r0-HWJobActions'[jobDurationHours]
			            ),
			            COUNTROWS(
			                FILTER(
			                    ALL('M-r0-HWJobActions'), // Use ALL to clear existing filters for cumulative calculation
			                    'M-r0-HWJobActions'[Endpoint] = CurrentEndpoint && 'M-r0-HWJobActions'[Week] <= CurrentWeek
			                )
			            ),
			            0 // Value if denominator is zero
			        ),
			        REMOVEFILTERS('M-r0-HWJobActions'[Week]), // Clear week filter for inner calculation
			        REMOVEFILTERS('M-r0-HWJobActions'[jobDurationHours]), // Clear jobDurationHours filter
			        REMOVEFILTERS('M-r0-HWJobActions'[timeGenerated]) // Clear timeGenerated filter
			    )
		lineageTag: 30a3b6d7-5f62-417b-9350-38314258e8c2

		annotation PBI_FormatHint = {"isGeneralNumber":true}

