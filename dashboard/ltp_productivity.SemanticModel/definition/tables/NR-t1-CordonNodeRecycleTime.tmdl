table NR-t1-CordonNodeRecycleTime
	lineageTag: 0df05b71-8de7-48a0-9a68-aa2ad7ec35fd

	measure 'Cordon Recycle Last' =
			
			VAR LastWeek = [MaxWeek2]
			VAR FilteredTableForLatWeek =
			    FILTER(
			        'NR-t1-CordonNodeRecycleTime',
			        'NR-t1-CordonNodeRecycleTime'[Week] = LastWeek
			    )
			VAR Result =
			    AVERAGEX(
			        FilteredTableForLatWeek,
			        'NR-t1-CordonNodeRecycleTime'[Node Recycle Time (Hour)]
			    )
			RETURN COALESCE(Result, 0)
		lineageTag: 31a8f54f-f526-4bb4-b439-08834a7ab10d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cordon Recycle Previous' = ```
			
			VAR PreviousWeek = [MaxWeek2]-1
			VAR FilteredTableForLatWeek =
			    FILTER(
			        'NR-t1-CordonNodeRecycleTime',
			        'NR-t1-CordonNodeRecycleTime'[Week] = PreviousWeek
			    )
			VAR Result = 
			    AVERAGEX(
			        FilteredTableForLatWeek,
			        'NR-t1-CordonNodeRecycleTime'[Node Recycle Time (Hour)]
			    )
			RETURN COALESCE(Result, 0)
			```
		lineageTag: 0be577ec-24e3-4ad3-a132-ded3604f8483

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Cordon Recycle Change' =
			
			IF(
			    [Cordon Recycle Previous] > [Cordon Recycle Last],
			    "decreased",
			    IF(
			        [Cordon Recycle Previous] < [Cordon Recycle Last],
			        "increased",
			        "unchanged"
			    )
			)
		lineageTag: b4c88911-d487-4cdb-98f4-44a33dd52df4

