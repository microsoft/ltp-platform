	partition A-r0-na = m
		mode: import
		queryGroup: Availability
		source =
				let
				    Source = AzureDataExplorer.Contents("azcore.centralus", "Fc", "let startdate = datetime(2025-03-20);#(lf)let enddate = now(); #(lf)let mi300 = cluster('https://azcore.centralus.kusto.windows.net').database('Fc').LogContainerPolicySnapshot   #(lf)| where PreciseTimeStamp between (startdate .. enddate)  #(lf)| where hardwareGeneration contains ""AmdMI300X""#(lf)| where Tenant contains ""CYS13PrdGPC02"" or Tenant contains ""LON64PrdGPC01"" or Tenant contains ""PAR40PrdGPC02"" or Tenant contains ""SJC24PrdGPC03""#(lf)| distinct Tenant;  #(lf)cluster('https://azcore.centralus.kusto.windows.net').database('AzureCP').MycroftNodeSnapshot#(lf)| where PreciseTimeStamp between (startdate .. enddate)  #(lf)| where ClusterName in (mi300)  #(lf)| where MachinePoolName contains ""MP2""#(lf)| distinct NodeId, MachinePoolName#(lf)| join kind=rightouter (#(lf)    cluster('https://azcore.centralus.kusto.windows.net').database('AzureCP').MycroftNodeHealthSnapshot#(lf)    | where PreciseTimeStamp between (startdate .. enddate)  #(lf)    | where ClusterName in (mi300) #(lf)) on NodeId#(lf)| extend Day = bin(PreciseTimeStamp, 1d)  #(lf)| summarize arg_max(PreciseTimeStamp, *) by NodeId, Day  #(lf)| summarize arg_max(PreciseTimeStamp, NsdState, AvailabilityState, ContainerCount, FaultInfo) by ClusterName, NodeId, Day  #(lf)| summarize#(lf)    ready_used =countif(NsdState == ""Ready"" and ContainerCount == 1), #(lf)    ready_avail_empty = countif(NsdState == ""Ready"" and AvailabilityState == ""Available"" and ContainerCount == 0),#(lf)    ofr = countif(NsdState == ""OutForRepair""),#(lf)    hi = countif(NsdState == ""HumanInvestigate""),#(lf)    exc = countif(NsdState == ""Excluded""),#(lf)    prob = countif(AvailabilityState == ""Probation""),#(lf)    suspected = countif(AvailabilityState == ""Suspected""),#(lf)    total = count(),#(lf)    ua = countif(NsdState == ""Ready"" and AvailabilityState == ""Unallocatable"")#(lf)    by ClusterName, Day#(lf)| extend DayOfWeek = dayofweek(Day) #(lf)| extend WeekStart = iif(DayOfWeek == 0d, startofweek(Day,-1) + 1d, startofweek(Day) + 1d)   #(lf)| project Day, Week = format_datetime(WeekStart, 'yyyy-MM-dd'), Cluster = ClusterName, Total = total, ReadyEmpty = ready_avail_empty, ReadyContainer=ready_used, OFR=ofr, Unallocatable=ua, HumanInvestigate=hi, Excluded=exc,Probation=prob,Suspected=suspected #(lf)| summarize  #(lf)    AvgTotal = round(avg(Total), 2),  #(lf)    AvgReadyEmpty = round(avg(ReadyEmpty), 2),  #(lf)    AvgReadyUsed = round(avg(ReadyContainer), 2),  #(lf)    AvgOFR = round(avg(OFR), 2),  #(lf)    AvgUnallocatable = round(avg(Unallocatable), 2),  #(lf)    AvgHumanInvestigate = round(avg(HumanInvestigate), 2),  #(lf)    AvgExcluded = round(avg(Excluded), 2),  #(lf)    AvgProbation = round(avg(Probation), 2),  #(lf)    AvgSuspected = round(avg(Suspected), 2)  #(lf)    by Week, Cluster  #(lf)| order by Week asc#(lf)| extend TIMESTAMP = todatetime(Week)#(lf)| extend WeekNum = weekofyear(startofweek(TIMESTAMP - 1d, 0))", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

