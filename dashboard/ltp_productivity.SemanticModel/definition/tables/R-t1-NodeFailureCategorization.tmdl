table R-t1-NodeFailureCategorization
	lineageTag: bcae397e-31fb-44ef-88c2-988bc1fb50df

	measure 'Top 1 Failure Categories' =
			
			VAR MaxWeekNumber = [MaxWeekR]
			VAR FilteredTable = FILTER('R-t1-NodeFailureCategorization', 'R-t1-NodeFailureCategorization'[Week] = MaxWeekNumber)
			VAR HasDataForMaxWeek =
			    CALCULATE(
			        COUNTROWS('R-t1-NodeFailureCategorization'),
			        'R-t1-NodeFailureCategorization'[Week] = MaxWeekNumber
			    )
			VAR MaxHardware = SUMX(FilteredTable, 'R-t1-NodeFailureCategorization'[Hardware])
			VAR MaxPlatform = SUMX(FilteredTable, 'R-t1-NodeFailureCategorization'[Platform])
			VAR MaxUser = SUMX(FilteredTable, 'R-t1-NodeFailureCategorization'[User])
			VAR MaxUnkonwn = SUMX(FilteredTable, 'R-t1-NodeFailureCategorization'[unknown])
			VAR MaxUncategorized = SUMX(FilteredTable, 'R-t1-NodeFailureCategorization'[uncategorized])
			VAR MaxValue = MAX(MaxHardware, MAX(MaxPlatform, MAX(MaxUser, MAX(MaxUnkonwn, MaxUncategorized))))
			VAR TotalFailures = (MaxHardware + MaxPlatform + MaxUser + MaxUnkonwn + MaxUncategorized)
			VAR RatioText =
			    IF(
			        TotalFailures = 0,
			        "NA", // If total is 0, set ratio to "NA"
			        FORMAT(MaxValue / TotalFailures, "0.0%") // Otherwise, calculate and format as percentage
			    )
			VAR Result =
			    SWITCH(
			        TRUE(),
			        MaxValue = MaxHardware, "Hardware (" & MaxValue & " instances, account for " & RatioText & " of total " & TotalFailures &" failures)",
			        MaxValue = MaxPlatform, "Platform (" & MaxValue &" instances, account for " & RatioText & " of total " & TotalFailures &" failures)",
			        MaxValue = MaxUser, "User (" & MaxValue & " instances, account for " & RatioText & " of total " & TotalFailures &" failures)",
			        MaxValue = MaxUnkonwn, "Unknown (" & MaxValue & " instances, account for " & RatioText & " of total " & TotalFailures &" failures)",
			        MaxValue = MaxUncategorized, "Uncategorized (" & MaxValue & " instances, account for " & RatioText & " of total " & TotalFailures &" failures)"
			    )
			RETURN
			IF(
			    HasDataForMaxWeek = 0,
			    "0 Failures",
			    Result
			)
		lineageTag: 302f23d5-b6ca-4b34-b37f-2023496f0677

