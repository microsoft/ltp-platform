	partition J-t4-JobDuration = calculated
		mode: import
		source = ```
				
				VAR JobSummaryData_Current = 
				    FILTER('J-r2-JobSummary', 'J-r2-JobSummary'[totalGpuCount] >= 0)
				VAR FailureCategories =
				    DATATABLE(
				        "exitCategory", STRING,
				        {
				            {"User Stop"},
				            {"Hardware Failure"},
				            {"Software Failure"}
				        }
				    )
				VAR Aggregated =
				    SUMMARIZE(
				        JobSummaryData_Current,
				        [Week],
				        [Endpoint],
				        "_AvgUserStop", AVERAGEX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "User Stop"), [jobDurationHours]),
				        "_AvgHardwareFailure", AVERAGEX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "Hardware Failure"), [jobDurationHours]),
				        "_AvgSoftwareFailure", AVERAGEX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "Software Failure"), [jobDurationHours]),
				        "_MaxUserStop", MAXX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "User Stop"), [jobDurationHours]),
				        "_MaxHardwareFailure", MAXX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "Hardware Failure"), [jobDurationHours]),
				        "_MaxSoftwareFailure", MAXX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "Software Failure"), [jobDurationHours]),
				        "_counts_UserStop", COUNTX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "User Stop"), [jobDurationHours]),
				        "_counts_HardwareFailure", COUNTX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "Hardware Failure"), [jobDurationHours]),
				        "_counts_SoftwareFailure", COUNTX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] = "Software Failure"), [jobDurationHours]),
				        "_counts_total", COUNTX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] IN FailureCategories), [jobDurationHours]),
				        "_MaxDuration", MAXX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] IN FailureCategories), [jobDurationHours]),
				        "_AvgDuration", AVERAGEX(FILTER(JobSummaryData_Current, [Week] = EARLIER([Week]) && [Endpoint] = EARLIER([Endpoint]) && [exitCategory] IN FailureCategories), [jobDurationHours])
				    )
				RETURN
				    Aggregated
				```

	annotation PBI_Id = 441027e086fa4ec48d75b684ec3eeb16

