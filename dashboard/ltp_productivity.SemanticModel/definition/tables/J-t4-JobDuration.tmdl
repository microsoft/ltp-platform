	measure nJDALastWeek = ```
			
			VAR LatestWeek = [MaxWeekR]
			VAR Result = 
			    CALCULATE(
			        [AvgDuration],
			        'J-r2-JobSummary'[Week] = LatestWeek
			    )
			RETURN COALESCE(Result , 0)
			```
		lineageTag: ab071cf0-6976-4347-a576-9221e39e7276

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'JDA Last Week' = ```
			
