	partition J-r2-JobSummary = m
		mode: import
		queryGroup: Job
		source =
				let
				    Source = AzureDataExplorer.Contents("luciatrainingplatform.westcentralus", "production", "let JobSummary = cluster('luciatrainingplatform.westcentralus.kusto.windows.net').database('production').JobSummary;#(lf)JobSummary#(lf)| summarize arg_max(timeGenerated, *) by jobId#(lf)| extend Week = weekofyear(startofweek(launchTime - 1d, 0)) // Monday as the start of the week", [MaxRows=null, MaxSize=null, NoTruncate=null, AdditionalSetStatements=null])
				in
				    Source

	annotation PBI_ResultType = Table

	annotation PBI_NavigationStepName = Navigation

