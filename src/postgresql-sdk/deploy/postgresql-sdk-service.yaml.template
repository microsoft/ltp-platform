apiVersion: batch/v1
kind: Job
metadata:
  name: postgresql-sdk-sync
spec:
  template:
    metadata:
      labels:
        app: postgresql-sdk-sync
    spec:
      restartPolicy: OnFailure
      initContainers:
      - name: wait-for-postgresql
        image: {{ cluster_cfg["cluster"]["docker-registry"]["prefix"] }}postgresql:{{ cluster_cfg["cluster"]["docker-registry"]["tag"] }}
        command:
          - /bin/bash
          - -c
          - |
            until pg_isready -h {{ cluster_cfg["postgresql"]["host"] }} -p {{ cluster_cfg["postgresql"]["port"] }} -U {{ cluster_cfg["postgresql"]["user"] }}; do
              echo "Waiting for PostgreSQL..."
              sleep 2
            done
            echo "PostgreSQL is ready!"
        env:
        - name: PGPASSWORD
          value: "{{ cluster_cfg['postgresql']['passwd'] }}"
      containers:
      - name: schema-sync
        image: {{ cluster_cfg["cluster"]["docker-registry"]["prefix"] }}postgresql-sdk:{{ cluster_cfg["cluster"]["docker-registry"]["tag"] }}
        imagePullPolicy: Always
        command:
          - /bin/bash
          - -c
          - |
            python /app/src/schema_manager.py sync && python /app/src/schema_manager.py check
        env:
        - name: POSTGRES_CONNECTION_STR
          value: "postgresql://{{ cluster_cfg['postgresql']['user'] }}:{{ cluster_cfg['postgresql']['passwd'] }}@{{ cluster_cfg['postgresql']['host'] }}:{{ cluster_cfg['postgresql']['port'] }}/{{ cluster_cfg['postgresql']['db'] }}"
        - name: POSTGRES_SCHEMA
          value: "{{ cluster_cfg['postgresql']['schema-name'] }}"
      imagePullSecrets:
      - name: {{ cluster_cfg["cluster"]["docker-registry"]["secret-name"] }}
